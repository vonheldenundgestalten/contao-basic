{
    "name": "vonheldenundgestalten/contao-basic",
    "description": "Basic stylings for all VHUG projects (for Contao 5.3.x)",
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Markus Milkereit",
            "email": "mm@vonheldenundgestalten.de",
            "role": "Developer"
        },
        {
            "name": "Marko Todić",
            "email": "drexplosiveweb@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "contao/core-bundle": "^5.3"
    },
    "replace": {
        "magmell-agentur/contao-basic": "@dev"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.3"
    },
    "extra": {
        "contao-manager-plugin": "VHUG\\ContaoBasic\\ContaoManager\\Plugin"
    },
    "autoload": {
        "psr-4": {
            "VHUG\\ContaoBasic\\": "src"
        },
        "classmap": [
            "contao/"
        ],
        "files": [
            "src/aliases.php"
        ]
    },
    "suggest": {
        "vonheldenundgestalten/contao-privacy": "Simple privacy handling for a small selection of typical services without external dependencies"
    }
}
